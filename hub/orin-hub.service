[Unit]
Description=Orin Home Hub
After=network-online.target tailscaled.service
Wants=network-online.target

[Service]
Type=simple
ExecStartPre=/bin/sleep 3
ExecStart=/home/hao/work/Orin_home/hub/run.sh
Environment=PATH=/home/hao/.local/bin:/usr/local/bin:/usr/bin:/bin
WorkingDirectory=/home/hao/work/Orin_home/hub
Restart=always
RestartSec=5
User=hao
Group=hao
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
